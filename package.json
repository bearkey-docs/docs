{
  "name": "document-web-design",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "ensure-categories": "node scripts/ensure-doc-categories.js",
    "prestart": "npm run prepare-docs",
    "start": "docusaurus start --host 0.0.0.0",
    "prebuild": "npm run prepare-docs",
    "build": "docusaurus build",
    "preserve": "npm run prepare-docs",
    "serve": "docusaurus serve --host 0.0.0.0",
    "clear": "docusaurus clear",
    "convert-doc-images": "node scripts/convert-doc-images-to-webp.js",
    "split-docs": "node scripts/split-doc-card-pages.js",
    "prepare-docs": "npm run convert-doc-images && npm run split-docs && npm run ensure-categories"
  },
  "dependencies": {
    "@docusaurus/core": "^3.8.1",
    "@docusaurus/preset-classic": "^3.8.1",
    "@easyops-cn/docusaurus-search-local": "0.55.2",
    "@mdx-js/react": "^3.1.0",
    "clsx": "^2.1.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.8.1"
  },
  "engines": {
    "node": ">=18.0"
  }
}
